            ],
            "type": "u64"
          },
          {
            "name": "signal_count",
            "docs": [
              "Number of signals published; doubles as the next signal index."
            ],
            "type": "u64"
          },
          {
            "name": "registered_at",
            "type": "i64"
          },
          {
            "name": "active",
            "docs": [
