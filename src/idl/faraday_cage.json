    {
      "name": "Provider",
      "docs": [
        "One record per provider wallet. PDA: [\"provider\", wallet]. Never closed,",
        "so the signal index keeps growing across unstake/restake cycles and old",
        "signal PDAs can never collide with new ones."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "wallet",
            "type": "pubkey"
          },
          {
            "name": "staked",
